# Which backend to use: poe | ollama | mock
PROVIDER=poe

# --- Poe (hosted models) ---  https://poe.com/api_key
POE_API_KEY=
POE_MODEL=gemini-3.5-flash

# --- Local Ollama ---  run `ollama serve` first
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Optional ---
# TEMPERATURE=0
# MAX_RETRIES=2
# RETRY_DELAY=2
